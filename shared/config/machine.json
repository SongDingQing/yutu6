{
  "schema_version": 1,
  "updated_at": "2026-07-20",
  "note": "玉兔6 环境配置机器可读子集。非密——不含任何密钥值。人读版见 environment.md。",
  "machines": {
    "old": { "user": "yutu", "home": "/Users/yutu", "role": "cold_backup_reference" },
    "new": { "user": "yutu6", "home": "/Users/yutu6", "role": "active_core" }
  },
  "paths": {
    "workspace": "~/玉兔6工作区",
    "secrets_vault": "~/.config/yutu6-secrets",
    "hermes": "~/.hermes/hermes-agent",
    "hermes_env": "~/.hermes/.env",
    "codex_skills": "~/.codex/skills",
    "codex_modules": "~/.codex/modules",
    "yuanxiao": "~/Projects/YuanXiao",
    "simulaid": "~/Simulaid",
    "kb_sqlite": "~/玉兔6工作区/knowledge/kb.sqlite"
  },
  "services": {
    "unified_startup": { "launchd": "com.yutu6.startup", "run_at_login": true, "reconcile_seconds": 600 },
    "console": { "port": 41218, "alias_port": 8799, "bind": ["127.0.0.1", "::1"], "launchd": "com.yutu6.console" },
    "model_pool": { "port": 3000, "bind": ["127.0.0.1"], "runtime": "orbstack" },
    "hermes_gateway": { "port": 8642, "status": "running", "launchd": "ai.hermes.gateway" },
    "hermes_voice_wake": { "status": "managed", "launchd": "com.yutu.hermes.voicewake" }
  },
  "runners": {
    "front_door": "codex",
    "codex": { "cmd": "codex", "model": "gpt-5.6-sol", "role": "secretary_orchestrator_engineering_and_repair", "version": "0.144.1", "login": "ok" },
    "hermes": { "cmd": "hermes", "role": "voice_feishu_entry_alt", "gateway": "not_started" },
    "peekaboo": { "cmd": "peekaboo", "role": "gui_desktop_control", "kind": "cli_and_mcp", "installed": true, "permissions_needed": ["screen_recording", "accessibility"] },
    "local_models": { "provider": "external_machine_endpoint", "ollama_on_mini": false }
  },
  "secrets_distribution": {
    "~/.hermes/.env": ["FEISHU_*", "BRAVE_*", "MINIMAX_*", "LLM_MODEL", "API_SERVER_*"],
    "~/Projects/YuanXiao/ops/config/yuanxiao.env": ["YUANXIAO_*"],
    "~/.ssh/": ["ssh_private_keys (not in secrets.env)"]
  },
  "backup": {
    "secrets_vault": "quark_netdisk_encrypted_archive",
    "workspace_snapshot": "yutu2_cold_backup",
    "workspace_source": "gitee_no_secrets"
  },
  "hard_constraints": {
    "secrets": "local_only_never_transmit_never_echo",
    "oauth_2fa": "manual_by_user"
  }
}
