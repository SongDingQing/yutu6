{
  "schema_version": 2,
  "updated_at": "2026-07-14",
  "note": "通用发行版的非密环境契约；实际路径和登录状态由初始化向导写入本机私有配置。",
  "paths": {
    "workspace": "${YUTU6_ROOT}",
    "private_config": "~/.config/yutu6",
    "provider_env": "~/.config/yutu6/providers.env",
    "setup_state": "~/.config/yutu6/setup-state.json",
    "codex_skills": "~/.codex/skills"
  },
  "services": {
    "console": {
      "port": 41218,
      "bind": ["127.0.0.1"],
      "required": true
    },
    "hermes_gateway": {
      "status": "optional"
    }
  },
  "runners": {
    "front_door": "codex",
    "codex": {
      "cmd": "codex",
      "role": "front_door_and_engineering",
      "setup_probe": "codex login status"
    },
    "claude": {
      "cmd": "claude",
      "role": "optional_board_or_executor",
      "optional": true
    },
    "peekaboo": {
      "cmd": "peekaboo",
      "role": "optional_gui_desktop_control",
      "optional": true,
      "permissions_needed": ["screen_recording", "accessibility"]
    }
  },
  "hard_constraints": {
    "secrets": "local_only_never_transmit_never_echo",
    "oauth_2fa": "manual_by_user",
    "project_specific_content": "install_via_project_pack"
  }
}
