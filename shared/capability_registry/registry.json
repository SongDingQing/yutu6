    "instruction_expansion_priority": [
      "explicit_named_skill_or_agent",
      "installed_project_pack",
      "cross_project_wrapper",
      "global_instruction_expansion_router"
    ],
    "project_boundary": "具体项目的 agent、skill、发布流程和业务资料不得进入通用发行版；项目能力包安装后才登记。",
