      "Hermes/Yutu voice workflow",
      "Feishu integrations",
      "multi-agent collaboration",
      "agent capability contracts",
      "ASR hotwords and corrections"
    ],
    "do_not_store": [
      "API keys",
      "passwords",
      "private tokens",
      "cookies",
      "full secrets from .env"
