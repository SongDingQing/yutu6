{
  "schema_version": 2,
  "updated_at": "2026-07-14",
  "note": "玉兔6 通用能力注册表。系统能力随发行版安装，具体项目能力通过 project-packs 独立接入。",
  "workspace_modules_dir": "shared/capability_registry/modules",
  "policy": {
    "lookup_first_for": [
      "persistent local customizations",
