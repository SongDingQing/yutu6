{
  "schema_version": 1,
  "updated_at": "2026-06-22",
  "purpose": "Shared non-secret capability and handoff manifest for Hermes/Yutu, Codex, and future local agents.",
  "safety": {
    "do_not_store": [
      "api_keys",
      "passwords",
      "private_tokens",
      "cookies",
      "full_env_files"
    ],
    "requires_confirmation": [
      "send_email",
      "send_files",
      "send_apk",
      "start_codex_on_local_project_from_voice_or_feishu",
      "destructive_or_high_impact_local_changes"
    ]
  },
  "agents": [
    {
      "id": "hermes-yutu",
      "name": "Hermes / 玉兔",
      "role": "front_door_router_and_voice_feishu_agent",
      "strengths": [
        "voice_wake",
        "spoken_replies",
        "feishu_messages",
        "feishu_confirmation_cards",
        "brave_search",
      "asr_hotwords_and_corrections",
        "confirmed_codex_scheduling",
        "user_facing_followups"
      ],
      "interfaces": [
        {
          "type": "feishu_gateway",
          "description": "Receives and sends Feishu messages and interactive cards."
        },
        {
          "type": "voice_wake",
          "description": "Receives microphone commands after wake phrase and mirrors voice records to Feishu."
        },
                {
                    "type": "plugin",
                    "name": "codex-handoff",
                    "description": "Sends confirmed immediate or scheduled local coding tasks to Codex."
                },
                {
                    "type": "planned_probe",
                    "name": "active_codex_session_contact",
                    "description": "Unverified future capability: test whether Hermes/Yutu can precisely contact the currently open Codex Desktop session with task id, acknowledgement, timeout, and fallback."
                }
            ],
      "entry_skills": [
        "$HOME/.hermes/skills/autonomous-ai-agents/multi-agent-collaboration-contract/SKILL.md",
        "$HOME/.hermes/skills/autonomous-ai-agents/codex-handoff/SKILL.md",
        "$HOME/.hermes/skills/autonomous-ai-agents/voice-asr-context/SKILL.md"
      ]
    },
    {
      "id": "codex",
      "name": "OpenAI Codex",
      "role": "chief_reasoning_architect_and_local_engineering_agent",
      "strengths": [
        "strongest_reasoning_brain",
        "cross_agent_architecture",
        "risk_assessment",
        "task_decomposition",
        "retrospective_synthesis",
        "local_file_edits",
        "repo_inspection",
        "tests_and_builds",
        "unity_project_changes",
        "apk_build_or_discovery",
        "document_artifact_generation",
        "scheduled_local_runs",
        "code_review",
        "gmail_connector_when_available",
        "project_pack_asset_pipelines",
        "session_limited_subagent_delegation",
        "same_machine_hermes_modification",
        "persistent_module_updates"
      ],
      "interfaces": [
        {
          "type": "codex_desktop",
          "description": "Interactive Codex Desktop session with local filesystem and app connectors."
        },
        {
          "type": "codex_cli",
          "description": "Local CLI invoked by Hermes codex-handoff after Feishu confirmation."
        },
        {
          "type": "gmail_connector",
          "description": "Send email when the Codex app Gmail connector is available and user intent is confirmed."
        }
      ],
      "entry_skills": [
        "~/.codex/skills/module-registry/SKILL.md",
        "~/.codex/skills/multi-agent-collaboration-contract/SKILL.md",
        "~/.codex/skills/hermes-yutu-voice-bridge/SKILL.md"
      ]
    },
    {
      "id": "it-engineer",
      "name": "IT 工程师",
      "role": "version_release_and_git_operations_agent",
      "strengths": [
        "four_part_versioning",
        "configured_git_remote_sync",
        "versioned_commit_and_push",
        "safe_revert_based_rollback",
        "release_audit"
      ],
      "interfaces": [
        {
          "type": "queue_agent",
          "queue": "projects/控制台/artifacts/queues/it_engineer",
          "description": "Receives version release and rollback tasks from secretary-tools or project-route direct routing."
        },
        {
          "type": "cli",
          "name": "version-manager",
          "description": "node projects/控制台/tools/version-manager.js release|rollback|status"
        }
      ],
      "entry_files": [
        "shared/agents/it-engineer/agent.json",
        "shared/agents/it-engineer/prompt.md",
        "projects/控制台/tools/version-manager.js",
        "VERSION.json"
      ],
      "confirmation_required": [
        "confirmed_rollback",
        "history_rewrite",
        "force_push",
        "unknown_external_send"
      ]
    }
  ],
  "routes": [
    {
      "id": "voice_or_feishu_to_codex_coding",
      "from": "hermes-yutu",
      "to": "codex",
      "when": [
        "local_code_change",
        "unity_game_feature",
        "test_or_build",
        "apk_requested",
        "document_or_file_return_requested",
        "repo_review"
      ],
      "requires": [
        "project_path",
        "task"
      ],
            "optional": [
                "verification",
                "deliver_apk",
                "deliver_document"
            ],
            "confirmation": "feishu_codex_handoff_card",
            "execution": "immediate_tasks_enter_codex_handoff_serial_queue",
            "queue": {
                "status": "active",
                "path": "$HOME/.hermes/codex-handoff/queue",
                "acknowledgement": "Feishu message includes queue id and number of tasks ahead",
                "scope": "Immediate Codex CLI handoff tasks only; ordinary Hermes chat is not globally serialized."
            }
        },
    {
      "id": "voice_or_feishu_to_scheduled_codex",
      "from": "hermes-yutu",
      "to": "codex",
      "when": [
        "delayed_codex_task",
        "recurring_codex_task",
        "timed_codex_task",
        "repeat_limited_codex_task"
      ],
      "requires": [
        "project_path",
        "task",
        "schedule"
      ],
      "optional": [
        "repeat",
        "verification",
        "deliver_apk",
        "deliver_document"
      ],
      "confirmation": "feishu_codex_scheduled_handoff_card",
      "persistence": [
        "$HOME/.hermes/cron/jobs.json",
        "$HOME/.hermes/scripts/codex-handoff",
        "$HOME/.hermes/codex-handoff/scheduled-runs"
      ]
    },
    {
      "id": "voice_to_confirmed_email_task",
      "from": "hermes-yutu",
      "to": "codex",
      "when": [
        "send_email",
        "send_search_results_to_email",
        "email_saved_contact"
      ],
      "known_contacts": {},
      "confirmation": "feishu_voice_task_card"
    },
    {
      "id": "console_change_to_it_engineer_release",
      "from": "codex",
      "to": "it-engineer",
      "when": [
        "console_change_ready_for_versioned_commit",
        "git_push_requested",
        "four_part_version_release_requested"
      ],
      "requires": [
        "changed_paths",
        "version_part",
        "update_summary"
      ],
      "execution": "node projects/控制台/secretary-tools.js it-release-request --part <manual|major|minor|fix> --message \"...\" --path <file>",
      "confirmation": "current trusted owner request is enough for release; destructive rollback still requires explicit confirmation"
    },
    {
      "id": "repair_to_it_engineer_safe_rollback",
      "from": "repair",
      "to": "it-engineer",
      "when": [
        "page_completely_unrepairable",
        "safe_version_rollback_needed"
      ],
      "requires": [
        "target_version_or_commit",
        "repair_reason"
      ],
      "execution": "node projects/控制台/secretary-tools.js it-rollback-request --target <version-or-commit> --reason \"...\"",
      "confirmation": "IT engineer must dry-run first; actual rollback requires owner confirmation and uses git revert, not history rewrite"
    },
        {
            "id": "codex_to_hermes_feishu_surface",
      "from": "codex",
      "to": "hermes-yutu",
      "when": [
        "needs_feishu_confirmation_card",
        "needs_feishu_gateway_delivery",
        "needs_voice_asr_context_update"
      ],
            "confirmation": "depends_on_action"
        },
        {
            "id": "hermes_to_active_codex_session_probe",
            "from": "hermes-yutu",
            "to": "codex",
            "status": "planned_unverified",
            "when": [
                "user_keeps_codex_session_open",
                "needs_precise_current_session_contact",
                "task_distribution_capability_probe"
            ],
            "requires": [
                "session_label",
                "task_id",
                "delivery_timestamp",
                "codex_acknowledgement",
                "timeout_seconds",
                "fallback_queue_or_handoff_path"
            ],
            "confirmation": "not_a_reliable_route_until_probe_passes",
            "safety_note": "Do not assume Hermes/Yutu can address the exact open Codex Desktop session or distribute arbitrary tasks until this probe is implemented and validated."
        }
  ],
  "module_registry": {
    "root": "shared/capability_registry/modules",
    "index": "shared/capability_registry/INDEX.md",
    "registry": "shared/capability_registry/registry.json"
  }
}
