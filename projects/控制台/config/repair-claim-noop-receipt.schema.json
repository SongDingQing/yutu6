{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yutu6.local/schemas/repair-claim-noop-receipt.schema.json",
  "title": "Repair claim-time deterministic no-op receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "task_id",
    "queue_agent",
    "queue_id",
    "ticket_id",
    "status",
    "action",
    "reason",
    "hash",
    "ticket",
    "completion_report",
    "steer",
    "provenance",
    "lock",
    "created_at",
    "receipt_hash"
  ],
  "properties": {
    "schema": { "const": "repair-claim-noop-receipt@1" },
    "task_id": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
    "queue_agent": { "const": "repair" },
    "queue_id": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
    "ticket_id": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
    "status": { "const": "done" },
    "action": { "const": "complete_without_runner" },
    "reason": { "const": "verified_completed_repair_ticket" },
    "hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "ticket": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": { "type": "string", "pattern": "^board/repair-tickets/[A-Za-z0-9._-]+\\.md$" },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "completion_report": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^projects/控制台/artifacts/repair-reports/[A-Za-z0-9._-]+\\.html$"
        },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "steer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "kind", "source", "sha256", "summary"],
      "properties": {
        "schema": { "const": "repair-closeout-noop-steer@1" },
        "kind": { "const": "repair_closeout_noop" },
        "source": { "enum": ["repair-closeout", "repair-lead"] },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "summary": { "type": "string", "maxLength": 160 }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "issuer", "path", "record_sha256"],
      "properties": {
        "schema": { "const": "repair-claim-noop-steer-provenance@1" },
        "issuer": {
          "enum": ["console-server:repair-closeout-noop", "repair-lead:closeout"]
        },
        "path": {
          "type": "string",
          "pattern": "^projects/控制台/artifacts/repair-claim-noop-steer-provenance/repair-[A-Za-z0-9._-]+-[a-f0-9]{64}\\.json$"
        },
        "record_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "lock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "runner_type", "path", "record_sha256"],
      "properties": {
        "kind": { "const": "privileged_runner_type_singleflight" },
        "runner_type": { "const": "codex-privileged" },
        "path": { "type": "string" },
        "record_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "created_at": { "type": "string", "format": "date-time" },
    "receipt_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}
