{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "yutu6-board-reproduction-receipt@1",
  "title": "Board controlled reproduction execution receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "receipt_id",
    "issuer",
    "execution_id",
    "task_id",
    "suggestion_id",
    "source_role",
    "source_trace_ref",
    "source_trace_line_sha256",
    "evidence_binding_sha256",
    "command_sha256",
    "status",
    "exit_code",
    "started_at",
    "completed_at",
    "result_ref",
    "result_line_sha256",
    "integrity_sha256"
  ],
  "properties": {
    "schema": { "const": "yutu6-board-reproduction-receipt@1" },
    "receipt_id": { "type": "string", "minLength": 1, "maxLength": 160 },
    "issuer": { "const": "console-controlled-runner" },
    "execution_id": { "type": "string", "minLength": 1, "maxLength": 200 },
    "task_id": { "type": "string", "minLength": 1, "maxLength": 240 },
    "suggestion_id": { "type": "string", "pattern": "^sug_[a-f0-9]{20}$" },
    "source_role": { "type": "string", "minLength": 1, "maxLength": 120 },
    "source_trace_ref": { "type": "string", "pattern": "^projects/控制台/[^\\n:]+:[1-9][0-9]*$" },
    "source_trace_line_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "evidence_binding_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "command_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "status": { "const": "reproduced" },
    "exit_code": { "const": 0 },
    "started_at": { "type": "string", "format": "date-time" },
    "completed_at": { "type": "string", "format": "date-time" },
    "result_ref": { "type": "string", "pattern": "^projects/控制台/[^\\n:]+:[1-9][0-9]*$" },
    "result_line_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "integrity_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}
