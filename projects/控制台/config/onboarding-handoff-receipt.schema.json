{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "onboarding-handoff-receipt.schema.json",
  "title": "Yutu6 onboarding handoff receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "plan_id",
    "agent_id",
    "context_digest",
    "understood",
    "questions",
    "capability_gaps",
    "first_smoke"
  ],
  "properties": {
    "schema": { "const": "onboarding-handoff-receipt@1" },
    "plan_id": { "type": "string", "pattern": "^ohp-[a-f0-9]{16}$" },
    "agent_id": { "type": "string", "minLength": 1 },
    "context_digest": { "type": "string", "minLength": 16 },
    "understood": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "questions": { "type": "array", "items": { "type": "string" } },
    "capability_gaps": { "type": "array", "items": { "type": "string" } },
    "first_smoke": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "status", "evidence_refs"],
      "properties": {
        "command": { "type": "string", "minLength": 1 },
        "status": { "enum": ["pass", "fail"] },
        "evidence_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
      }
    }
  }
}
