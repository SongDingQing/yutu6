{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yutu6.local/schemas/repair-closeout-noop-steer.schema.json",
  "title": "Trusted repair closeout no-op steer",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "kind",
    "source",
    "action",
    "queue_agent",
    "queue_id",
    "ticket_id",
    "ticket_sha256",
    "report_path",
    "report_sha256",
    "completion_fingerprint"
  ],
  "properties": {
    "schema": { "const": "repair-closeout-noop-steer@1" },
    "kind": { "const": "repair_closeout_noop" },
    "source": { "enum": ["repair-closeout", "repair-lead"] },
    "action": { "const": "complete_without_runner_if_verified" },
    "queue_agent": { "const": "repair" },
    "queue_id": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
    "ticket_id": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
    "ticket_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "report_path": {
      "type": "string",
      "pattern": "^projects/控制台/artifacts/repair-reports/[A-Za-z0-9._-]+\\.html$"
    },
    "report_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "completion_fingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "issued_at": { "type": "string", "format": "date-time" },
    "summary": { "type": "string", "maxLength": 160 },
    "force_review": { "type": "boolean" }
  }
}
