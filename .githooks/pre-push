#!/usr/bin/env bash
# 玉兔6 pre-push 硬约束:推送前扫描"本次推送将新增到远端的所有提交内容",命中即阻断。
# 这是最后一道本地闸门 —— 即便某次 commit 绕过了 pre-commit,推送前仍会被逐提交内容复查。
# 启用: git config core.hooksPath .githooks
# 绕过(紧急): SKIP_SECRET_SCAN=1 git push ...
set -euo pipefail
ROOT="$(git rev-parse --show-toplevel)"
if [ "${SKIP_SECRET_SCAN:-0}" = "1" ]; then
  echo "⚠️  SKIP_SECRET_SCAN=1:已跳过 pre-push 密钥扫描" >&2
  mkdir -p "$ROOT/security" 2>/dev/null
  printf '%s\tpre-push\t%s\t(push bypass)\n' "$(date -u +%FT%TZ)" "$(whoami)" >> "$ROOT/security/skip-audit.log" 2>/dev/null || true
  exit 0
fi
if ! command -v node >/dev/null 2>&1; then
  echo "❌ pre-push:未找到 node;拒绝推送" >&2
  exit 1
fi

Z40="0000000000000000000000000000000000000000"
status=0
# git 通过 stdin 传入: <local ref> <local sha> <remote ref> <remote sha>
while read -r local_ref local_sha remote_ref remote_sha; do
  [ -z "${local_sha:-}" ] && continue
  [ "$local_sha" = "$Z40" ] && continue   # 删除分支,无内容可扫
  if [ "$remote_sha" = "$Z40" ]; then
    # 远端全新分支:扫本地该分支不在其它已推分支中的全部提交
    range=$(git rev-list "$local_sha" --not --remotes 2>/dev/null | tail -1)
    if [ -n "$range" ]; then
      scan_range="${range}^..${local_sha}"
      # 若 range 是根提交(无父),退化为扫该分支全部可达提交
      if ! git rev-parse "${range}^" >/dev/null 2>&1; then scan_range="$local_sha"; fi
    else
      scan_range="$local_sha"
    fi
  else
    scan_range="${remote_sha}..${local_sha}"
  fi
  echo "🔍 pre-push 密钥扫描范围: $scan_range" >&2
  if echo "$scan_range" | grep -q '\.\.'; then
    node "$ROOT/security/secret-scan.js" --range "$scan_range" || status=1
  else
    node "$ROOT/security/secret-scan.js" --tracked || status=1
  fi
done
exit $status
